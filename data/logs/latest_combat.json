  {
    "type": "stat_change",
    "round": 3,
    "actor_id": "08d040bc-a871-46fa-865c-7be14d47d3b6",
    "actor_name": "\u041d\u043e\u0432\u044b\u0439 \u0443\u0447\u0430\u0441\u0442\u043d\u0438\u043a",
    "details": {
      "stat_key": "Note",
      "stat_name": "Note",
      "message": "Note: \u0441\u0442\u0430\u043d\u0435\u0442 \u043b\u043e\u0440\u0434\u043c -> \u0410-\u0430-\u0430, \u043f\u043e\u043d\u044f\u043b\u0430 \u0442\u0432\u043e\u044e \u043c\u044b\u0441\u043b\u044c! \u0422\u0438\u043f\u0430 \u0432\u043d\u0443\u0442\u0440\u0435\u043d\u043d\u0438\u0439 \u00ab\u0433\u043e\u043b\u043e\u0441 \u0441\u043e\u0432\u0435\u0441\u0442\u0438\u00bb \u0434\u043b\u044f \u041a\u0443\u0440\u0441\u043e\u0440\u0430, \u0447\u0442\u043e\u0431\u044b \u043e\u043d \u0441\u0430\u043c \u0441\u0435\u0431\u044f \u0431\u0438\u043b \u043f\u043e \u0432\u0438\u0440\u0442\u0443\u0430\u043b\u044c\u043d\u044b\u043c \u0440\u0443\u043a\u0430\u043c, \u043f\u0440\u0435\u0436\u0434\u0435 \u0447\u0435\u043c \u0432\u043e\u043e\u0431\u0449\u0435 \u043f\u043e\u043a\u0430\u0437\u0430\u0442\u044c \u043a\u043e\u0434 \u0442\u0435\u0431\u0435? \u0421\u043b\u0443\u0448\u0430\u0439, \u044d\u0442\u043e \u043f\u0440\u043e\u0441\u0442\u043e \u043e\u0444\u0438\u0433\u0435\u043d\u043d\u0430\u044f \u0438\u0434\u0435\u044f. \u041f\u0440\u044f\u043c\u043e \u043a\u0430\u043a \u043f\u043e\u0441\u0430\u0434\u0438\u0442\u044c \u0437\u0430 \u0441\u0442\u043e\u043b \u0434\u0443\u0448\u043d\u043e\u0433\u043e \u00ab\u0410\u0434\u0432\u043e\u043a\u0430\u0442\u0430 \u041f\u0440\u0430\u0432\u0438\u043b\u00bb (Rules Lawyer), \u043a\u043e\u0442\u043e\u0440\u044b\u0439 \u0431\u0443\u0434\u0435\u0442 \u0434\u043e\u043a\u0430\u043f\u044b\u0432\u0430\u0442\u044c\u0441\u044f \u0434\u043e \u043a\u0430\u0436\u0434\u043e\u0439 \u043c\u0435\u0445\u0430\u043d\u0438\u043a\u0438, \u043f\u043e\u043a\u0430 \u043c\u0430\u0441\u0442\u0435\u0440 \u043d\u0435 \u0432\u0438\u0434\u0438\u0442.",
      "color": "#a1a1aa",
